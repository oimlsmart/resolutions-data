---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import OimlLayout from '../../../layouts/OimlLayout.astro'
import { pickLocalizedValue, urlPrefix } from '../../../i18n/index.js'

export function getStaticPaths() {
  const urns = Object.keys(payloads.decisionByUrn)
  const nonDefault = cfg.locales.filter((l) => (l.routePrefix ?? '') !== '')
  return urns.flatMap((urn) =>
    nonDefault.map((loc) => ({
      params: { lang: loc.code, urn },
      props: { decision: payloads.decisionByUrn[urn] },
    })),
  )
}

const { decision } = Astro.props
const lang = Astro.params.lang ?? cfg.site.locale
const prefix = urlPrefix(cfg, lang)
const title = pickLocalizedValue(decision.title, lang, decision.urn ?? '')
const actions = decision.actions ?? []
const considerations = decision.considerations ?? []
---

<OimlLayout lang={lang} title={title}>
  <div class="res-page std-page">
    <a href={`${prefix}decisions`} class="std-page__back">← Decisions</a>
    <h1 class="std-page__title">{title}</h1>
    <p><code>{decision.urn}</code></p>

    {actions.length > 0 && (
      <section>
        <h2>Actions</h2>
        <ul>
          {actions.map((a) => (
            <li><strong>{a.type}</strong> {pickLocalizedValue(a.message, lang)}</li>
          ))}
        </ul>
      </section>
    )}

    {considerations.length > 0 && (
      <section>
        <h2>Considerations</h2>
        <ul>
          {considerations.map((c) => (
            <li>{pickLocalizedValue(c.message, lang)}</li>
          ))}
        </ul>
      </section>
    )}
  </div>
</OimlLayout>
