---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import OimlLayout from '../../layouts/OimlLayout.astro'
import { pickLocalizedValue, urlPrefix } from '../../i18n/index.js'

const lang = cfg.site.locale
const prefix = urlPrefix(cfg, lang)
const items = payloads.meetingsList.items
---

<OimlLayout lang={lang} title="Meetings">
  <div class="res-page">
    <h1>Meetings</h1>
    <ul class="meeting-list">
      {items.map((m) => (
        <li>
          <a href={`${prefix}meetings/${encodeURIComponent(m.urn)}`}>
            {pickLocalizedValue(m.title, lang, m.urn)}
          </a>
          {m.startDate && <span> — {m.startDate}</span>}
        </li>
      ))}
    </ul>
  </div>
</OimlLayout>
