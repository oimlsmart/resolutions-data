---
import cfg from 'virtual:edoxen-config'
import { urlPrefix, localePrefixOf } from '../utils/url.js'
import '../assets/main.css'

const OIML = {
  name: 'OIML',
  title: 'International Organization of Legal Metrology',
  tagline: 'Resolutions of the CIML and the OIML Conference',
  scope: 'Legal metrology — the practice and science of measurement that affects trade, health, safety, and the environment.',
  links: {
    oiml: 'https://www.oiml.org',
    ciml: 'https://www.oiml.org/en/structure/ciml/sites',
    conference: 'https://www.oiml.org/en/structure/conference/sites',
    bulletin: 'https://www.oiml.org/en/publications/oiml-bulletin',
    github: 'https://github.com/oimlsmart',
    linkedin: 'https://www.linkedin.com/company/organisation-internationale-de-métrologie-légale',
  },
}

interface Props {
  lang?: string
  title?: string
}
const { lang = cfg.site.locale, title } = Astro.props
const prefix = urlPrefix(cfg.site.basePath, localePrefixOf(cfg.locales, lang))
const pageTitle = title ? `${title} | ${cfg.site.title}` : cfg.site.title
const otherLang = lang === 'en' ? 'fr' : 'en'
const otherPrefix = urlPrefix(cfg.site.basePath, localePrefixOf(cfg.locales, otherLang))
const currentPath = Astro.url.pathname.replace(/^\/[^/]+\/[^/]+/, '').replace(/\/$/, '')
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${cfg.site.basePath}favicon.svg`} />
    <link rel="icon" type="image/png" href={`${cfg.site.basePath}favicon-96x96.png`} sizes="96x96" />
    <link rel="shortcut icon" href={`${cfg.site.basePath}favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${cfg.site.basePath}apple-touch-icon.png`} />
    <link rel="manifest" href={`${cfg.site.basePath}site.webmanifest`} />
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <div class="site-brand-bar" aria-hidden="true"></div>
    <header id="nav-header" class="site-header">
      <div class="site-header__inner">
        <a href={prefix} class="site-header__logo">
          <img src={`${cfg.site.basePath}assets/oiml-logo.svg`} alt="OIML" class="site-header__logo-img site-header__logo-img--theme" />
          <span class="site-header__logo-text">
            {OIML.name}
            <span class="site-header__logo-subtitle">{OIML.title}</span>
          </span>
        </a>

        <nav class="site-header__nav">
          <a href={prefix} class="site-header__nav-link">{lang === 'fr' ? 'Résolutions' : 'Resolutions'}</a>
          <a href={`${prefix}meetings`} class="site-header__nav-link">{lang === 'fr' ? 'Réunions' : 'Meetings'}</a>
          <a href={`${prefix}about`} class="site-header__nav-link">{lang === 'fr' ? 'À propos' : 'About'}</a>
        </nav>

        <div class="site-header__actions">
          <div class="lang-toggle" role="group" aria-label="Switch language">
            <a href={prefix} class={`lang-toggle__btn ${lang === 'en' ? 'lang-toggle__btn--active' : ''}`}>EN</a>
            <a href={otherPrefix} class={`lang-toggle__btn ${lang === 'fr' ? 'lang-toggle__btn--active' : ''}`}>FR</a>
          </div>
          <div class="site-header__external-links">
            <a href={OIML.links.oiml} target="_blank" rel="noopener noreferrer" class="site-header__icon-btn" aria-label="Official website" title="Official website">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </a>
          </div>
          <button type="button" class="site-header__icon-btn" aria-label="Toggle dark mode" id="theme-toggle-btn">
            <svg class="header-icon icon-sun" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            <svg class="header-icon icon-moon" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
          </button>
        </div>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__grid">
          <div class="site-footer__brand">
            <a href={prefix} class="site-footer__logo">
              <img src={`${cfg.site.basePath}assets/oiml-logo.svg`} alt="OIML" class="site-footer__logo-img site-footer__logo-img--theme" />
              <span class="site-footer__logo-text">{OIML.name}</span>
            </a>
            <p class="site-footer__tagline">{OIML.title}</p>
            <p class="site-footer__scope">{OIML.scope}</p>
          </div>

          <div>
            <h4 class="site-footer__heading">{lang === 'fr' ? 'Explorer' : 'Explore'}</h4>
            <ul class="site-footer__links">
              <li><a href={prefix} class="site-footer__link">{lang === 'fr' ? 'Résolutions' : 'Resolutions'}</a></li>
              <li><a href={`${prefix}meetings`} class="site-footer__link">{lang === 'fr' ? 'Réunions' : 'Meetings'}</a></li>
              <li><a href={`${prefix}about`} class="site-footer__link">{lang === 'fr' ? 'À propos' : 'About'}</a></li>
            </ul>
          </div>

          <div>
            <h4 class="site-footer__heading">{lang === 'fr' ? 'Liens' : 'Links'}</h4>
            <ul class="site-footer__links">
              <li><a href={OIML.links.oiml} class="site-footer__link" target="_blank" rel="noopener noreferrer">{lang === 'fr' ? 'Site officiel' : 'Official Website'}</a></li>
              <li><a href={OIML.links.ciml} class="site-footer__link" target="_blank" rel="noopener noreferrer">{lang === 'fr' ? 'Réunions CIML' : 'CIML Meetings'}</a></li>
              <li><a href={OIML.links.conference} class="site-footer__link" target="_blank" rel="noopener noreferrer">{lang === 'fr' ? 'Conférences' : 'Conferences'}</a></li>
              <li><a href={OIML.links.bulletin} class="site-footer__link" target="_blank" rel="noopener noreferrer">{lang === 'fr' ? 'Bulletin OIML' : 'OIML Bulletin'}</a></li>
              <li><a href={OIML.links.github} class="site-footer__link" target="_blank" rel="noopener noreferrer">GitHub</a></li>
              <li><a href={OIML.links.linkedin} class="site-footer__link" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
            </ul>
          </div>
        </div>
        <div class="site-footer__bottom">
          <p class="site-footer__copy">
            &copy; {new Date().getFullYear()} {OIML.name}
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function() {
        var btn = document.getElementById('theme-toggle-btn');
        if (!btn) return;
        var sun = btn.querySelector('.icon-sun');
        var moon = btn.querySelector('.icon-moon');
        function updateIcons() {
          var isDark = document.documentElement.classList.contains('dark');
          if (sun) sun.style.display = isDark ? 'none' : '';
          if (moon) moon.style.display = isDark ? '' : 'none';
        }
        updateIcons();
        btn.addEventListener('click', function() {
          document.documentElement.classList.toggle('dark');
          var isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcons();
        });
      })();
    </script>
  </body>
</html>
