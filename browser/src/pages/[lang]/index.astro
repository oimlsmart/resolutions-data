---
import cfg from 'virtual:edoxen-config'
import payloads from 'virtual:edoxen-payloads'
import OimlLayout from '../../layouts/OimlLayout.astro'
import { urlPrefix, localePrefixOf, safePickLocalizedValue } from '../../utils/url.js'
import { loadMeetings } from '../../utils/meetings.js'

export function getStaticPaths() {
  return cfg.locales
    .filter((l) => (l.routePrefix ?? '') !== '')
    .map((l) => ({ params: { lang: l.code } }))
}

const lang = Astro.params.lang ?? cfg.site.locale
const prefix = urlPrefix(cfg.site.basePath, localePrefixOf(cfg.locales, lang))
const items = payloads.decisionsList.items
const totalDecisions = items.length
const meetings = await loadMeetings()
const years = [...new Set(items.map((d) => d.dates?.[0]?.date?.slice(0, 4)).filter(Boolean))].sort((a, b) => Number(b) - Number(a))
const earliest = years[years.length - 1] ?? ''
const latest = years[0] ?? ''
---

<OimlLayout lang={lang}>
  <div class="home-page">
    <div class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title">{cfg.site.title}</h1>
        <p class="hero-subtitle">
          {totalDecisions} decisions from {meetings.length} meetings, spanning {earliest} to {latest}.
        </p>
        <div class="hero-actions">
          <a href={`${prefix}decisions`} class="hero-btn hero-btn--primary">Browse Decisions</a>
          <a href={`${prefix}meetings`} class="hero-btn hero-btn--secondary">Browse Meetings</a>
        </div>
      </div>
    </div>

    <div class="res-page">
      <div class="std-filter__meta">
        <span>Showing all {totalDecisions} decisions</span>
      </div>

      <div class="std-results">
        {items.map((d) => (
          <a href={`${prefix}decisions/${encodeURIComponent(d.urn)}`} class="std-results__card">
            <div class="card-header-row">
              <div class="std-results__name">
                <span>{d.identifier}</span>
              </div>
              {d.dates?.[0]?.date && <span class="badge-year">{d.dates[0].date.slice(0, 4)}</span>}
            </div>
            <div class="std-results__title">
              {safePickLocalizedValue(d.title, lang, d.urn)}
            </div>
            <div class="card-footer">
              <div class="card-meta-bottom">
                {d.bodyType && <span class="std-results__badge">{d.bodyType}</span>}
                {d.dates?.[0]?.date && <span class="std-results__badge badge-date">{d.dates[0].date}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</OimlLayout>
