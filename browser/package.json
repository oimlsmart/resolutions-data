{
  "name": "oiml-resolutions-browser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-data.mjs && vite",
    "build": "node scripts/build-data.mjs && vue-tsc -b && vite-ssg build && node scripts/post-build.mjs",
    "preview": "vite preview",
    "test": "node --test scripts/specs/*.test.mjs src/domain/*.test.mjs",
    "test:transforms": "node --test scripts/specs/transforms.test.mjs",
    "test:domain": "node --test src/domain/branded.test.mjs",
    "validate:yaml": "cd ../scripts/specs && bundle exec rspec yaml_validation_spec.rb"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@unhead/vue": "^3.1.4",
    "flexsearch": "^0.7.31",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "js-yaml": "^4.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  },
  "description": "Web browser for OIML CIML and Conference resolutions."
}
