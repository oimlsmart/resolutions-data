# OCR cache: the JSON responses (reference-docs/.ocr/raw/) are
# reproducible from PDFs via scripts/ocr/run.rb and are large; keep
# them out of git. The MARKDOWN digest (reference-docs/.ocr/md/)
# is the project data we author against — track it.
reference-docs/.ocr/raw/

# Browser build artifacts (reproducible via `npm run build`)
browser/dist/
browser/.vite/
browser/tsconfig.tsbuildinfo
browser/node_modules/

# Ruby
.bundle/
vendor/

# OS / editor
.DS_Store
*.tmp
*.bak
*.log
